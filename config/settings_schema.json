[
  {
    "name": "theme_info",
    "theme_name": "Tway Motorsports",
    "theme_version": "1.0.0",
    "theme_author": "Tway Motorsports",
    "theme_documentation_url": "https://twaymotorsports.com",
    "theme_support_url": "https://twaymotorsports.com/contact"
  },
  {
    "name": "Brand",
    "settings": [
      {
        "type": "image_picker",
        "id": "logo",
        "label": "Logo (dark background)"
      },
      {
        "type": "range",
        "id": "logo_height",
        "min": 20,
        "max": 60,
        "step": 2,
        "unit": "px",
        "label": "Logo height (desktop)",
        "default": 32
      },
      {
        "type": "image_picker",
        "id": "favicon",
        "label": "Favicon"
      }
    ]
  },
  {
    "name": "Colors",
    "settings": [
      {
        "type": "color",
        "id": "color_background",
        "label": "Background",
        "default": "#0a0a0b"
      },
      {
        "type": "color",
        "id": "color_foreground",
        "label": "Foreground / Text",
        "default": "#f9f9fa"
      },
      {
        "type": "color",
        "id": "color_surface",
        "label": "Surface",
        "default": "#141416"
      },
      {
        "type": "color",
        "id": "color_accent",
        "label": "Accent (Tway green)",
        "default": "#8fe038"
      },
      {
        "type": "color",
        "id": "color_muted",
        "label": "Muted text",
        "default": "#8a8a90"
      }
    ]
  },
  {
    "name": "Layout",
    "settings": [
      {
        "type": "range",
        "id": "container_max",
        "min": 1200,
        "max": 1600,
        "step": 20,
        "unit": "px",
        "label": "Max container width",
        "default": 1440
      }
    ]
  },
  {
    "name": "Social",
    "settings": [
      { "type": "text", "id": "social_instagram", "label": "Instagram URL", "default": "https://www.instagram.com/twaymotorsports/" },
      { "type": "text", "id": "social_youtube", "label": "YouTube URL" },
      { "type": "text", "id": "social_facebook", "label": "Facebook URL" },
      { "type": "text", "id": "social_tiktok", "label": "TikTok URL" }
    ]
  }
]