<section class="section-pad">
  <div class="container-wide">
    {%- if section.settings.heading != blank -%}<h2 class="rich-text__heading" style="margin-bottom: 2rem;">{{ section.settings.heading }}</h2>{%- endif -%}
    <div class="gallery-grid">
      {%- for block in section.blocks -%}
        <figure class="gallery-tile" {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            {{ block.settings.image | image_url: width: 1200 | image_tag: alt: block.settings.caption, loading: 'lazy', class: 'gallery-tile__img' }}
          {%- elsif block.settings.default_asset != blank -%}
            <img src="{{ block.settings.default_asset | asset_url }}" alt="{{ block.settings.caption | escape }}" loading="lazy" class="gallery-tile__img">
          {%- endif -%}
          {%- if block.settings.caption != blank -%}<figcaption class="gallery-tile__cap">{{ block.settings.caption }}</figcaption>{%- endif -%}
        </figure>
      {%- endfor -%}
    </div>
  </div>
</section>
{% schema %}
{
  "name": "Image gallery",
  "max_blocks": 24,
  "settings": [{ "type": "text", "id": "heading", "label": "Heading" }],
  "blocks": [
    { "type": "image", "name": "Image", "settings": [
      { "type": "image_picker", "id": "image", "label": "Image" },
      { "type": "text", "id": "default_asset", "label": "Default asset filename (bundled)" },
      { "type": "text", "id": "caption", "label": "Caption" }
    ]}
  ],
  "presets": [{ "name": "Image gallery", "blocks": [{ "type": "image" }, { "type": "image" }, { "type": "image" }] }]
}
{% endschema %}