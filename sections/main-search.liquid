<div class="container-wide section-pad">
  <p class="eyebrow" style="margin-bottom: 1rem;">{{ section.settings.eyebrow | default: 'Search' }}</p>
  <h1 style="font-size: clamp(1.75rem, 4vw, 3rem); margin-bottom: 2rem;">
    {%- if search.performed -%}Results for "{{ search.terms | escape }}"{%- else -%}{{ section.settings.heading | default: 'Find your part' }}{%- endif -%}
  </h1>
  <form action="{{ routes.search_url }}" method="get" role="search" class="search-form">
    <input type="hidden" name="type" value="product">
    <input type="search" name="q" value="{{ search.terms | escape }}" placeholder="{{ section.settings.placeholder | default: 'Search parts...' }}" class="search-form__input" autofocus>
    <button type="submit" class="btn-primary">Search</button>
  </form>
  {%- if search.performed -%}
    {%- if search.results_count > 0 -%}
      <p class="search-meta">{{ search.results_count }} result{% if search.results_count != 1 %}s{% endif %}</p>
      {%- paginate search.results by 24 -%}
        <div class="product-grid">
          {%- for item in search.results -%}
            {%- if item.object_type == 'product' -%}{% render 'product-card', product: item %}{%- endif -%}
          {%- endfor -%}
        </div>
        {%- if paginate.pages > 1 -%}
          <nav class="pagination" aria-label="Pagination">{{ paginate | default_pagination }}</nav>
        {%- endif -%}
      {%- endpaginate -%}
    {%- else -%}
      <div class="empty-state"><p style="color: var(--muted-foreground);">No results. Try a different search.</p></div>
    {%- endif -%}
  {%- endif -%}
</div>
{% schema %}
{
  "name": "Search",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Search" },
    { "type": "text", "id": "heading", "label": "Idle heading", "default": "Find your part" },
    { "type": "text", "id": "placeholder", "label": "Input placeholder", "default": "Search parts..." }
  ],
  "presets": [{ "name": "Search" }]
}
{% endschema %}