<section class="section-pad">
  <div class="container-wide contact-wrap">
    <div class="contact-info">
      {%- if section.settings.eyebrow != blank -%}<p class="eyebrow">{{ section.settings.eyebrow }}</p>{%- endif -%}
      <h2 class="rich-text__heading">{{ section.settings.heading | default: 'Get in touch' }}</h2>
      {%- for block in section.blocks -%}
        {%- if block.type == 'detail' -%}
          <div class="contact-detail" {{ block.shopify_attributes }}>
            <div class="contact-detail__label">{{ block.settings.label }}</div>
            <div class="contact-detail__value">{{ block.settings.value }}</div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
    {%- form 'contact', class: 'contact-form' -%}
      <div class="field"><label for="contact-name">Name</label><input id="contact-name" type="text" name="contact[name]" required></div>
      <div class="field"><label for="contact-email">Email</label><input id="contact-email" type="email" name="contact[email]" required></div>
      <div class="field"><label for="contact-phone">Phone</label><input id="contact-phone" type="tel" name="contact[phone]"></div>
      <div class="field"><label for="contact-body">Message</label><textarea id="contact-body" name="contact[body]" rows="6" required></textarea></div>
      <button type="submit" class="btn-primary">Send message</button>
      {%- if form.posted_successfully? -%}<p class="form-success">Thanks — we'll be in touch shortly.</p>{%- endif -%}
      {%- if form.errors -%}<p class="form-error">{{ form.errors | default_errors }}</p>{%- endif -%}
    {%- endform -%}
  </div>
</section>
{% schema %}
{
  "name": "Contact form",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Contact" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Get in touch" }
  ],
  "blocks": [
    { "type": "detail", "name": "Detail", "settings": [
      { "type": "text", "id": "label", "label": "Label" },
      { "type": "richtext", "id": "value", "label": "Value" }
    ]}
  ],
  "presets": [{ "name": "Contact form", "blocks": [
    { "type": "detail", "settings": { "label": "Address", "value": "<p>Orange, CA</p>" } },
    { "type": "detail", "settings": { "label": "Phone", "value": "<p>(714) 410-1820</p>" } },
    { "type": "detail", "settings": { "label": "Hours", "value": "<p>Mon–Fri 9AM–5PM</p>" } }
  ]}]
}
{% endschema %}