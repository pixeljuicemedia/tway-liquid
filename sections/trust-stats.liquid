<section class="trust-stats hairline-t">
  <div class="container-wide section-pad-sm">
    <div class="trust-stats__grid">
      {%- for block in section.blocks -%}
        <div class="trust-stat" {{ block.shopify_attributes }}>
          <p class="trust-stat__num">{{ block.settings.number }}</p>
          <p class="trust-stat__label">{{ block.settings.label }}</p>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Trust stats",
  "blocks": [
    { "type": "stat", "name": "Stat", "settings": [
      { "type": "text", "id": "number", "label": "Number", "default": "20+" },
      { "type": "text", "id": "label", "label": "Label", "default": "Years Experience" }
    ] }
  ],
  "max_blocks": 6,
  "presets": [{
    "name": "Trust stats",
    "blocks": [
      { "type": "stat", "settings": { "number": "20+", "label": "Years Experience" } },
      { "type": "stat", "settings": { "number": "500+", "label": "Track Cars Built" } },
      { "type": "stat", "settings": { "number": "10,000+", "label": "Parts Installed" } },
      { "type": "stat", "settings": { "number": "100%", "label": "Performance Focused" } }
    ]
  }]
}
{% endschema %}