<section class="curated-collections hairline-t bg-carbon">
  <div class="container-wide section-pad">
    <div class="section-header">
      <div>
        <p class="eyebrow">{{ section.settings.eyebrow | default: 'Shop by Category' }}</p>
        <h2 class="section-title">{{ section.settings.heading }}</h2>
      </div>
      <a href="{{ section.settings.view_all_link | default: routes.all_products_collection_url }}" class="btn-ghost">{{ section.settings.view_all_label | default: 'Full Catalog' }} &rarr;</a>
    </div>
    <div class="curated-grid">
      {%- for block in section.blocks -%}
        <a href="{{ block.settings.link }}" class="curated-card {% if forloop.first %}curated-card--wide{% endif %}" {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            <img src="{{ block.settings.image | image_url: width: 900 }}" alt="{{ block.settings.title | escape }}" loading="lazy" width="900" height="1200">
          {%- elsif block.settings.default_asset != blank -%}
            <img src="{{ block.settings.default_asset | asset_url }}" alt="{{ block.settings.title | escape }}" loading="lazy" width="900" height="1200">
          {%- endif -%}
          <div class="curated-card__grad"></div>
          <div class="curated-card__body">
            {%- if block.settings.meta != blank -%}<p class="eyebrow">{{ block.settings.meta }}</p>{%- endif -%}
            <h3>{{ block.settings.title }}</h3>
            <span class="curated-card__cta">Shop {{ block.settings.title }} &rarr;</span>
          </div>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Curated collections",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Shop by Category" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Pick your platform. Pick your podium." },
    { "type": "text", "id": "view_all_label", "label": "View all label", "default": "Full Catalog" },
    { "type": "url", "id": "view_all_link", "label": "View all link" }
  ],
  "blocks": [
    { "type": "tile", "name": "Tile", "settings": [
      { "type": "text", "id": "title", "label": "Title", "default": "Aero" },
      { "type": "text", "id": "meta", "label": "Meta", "default": "48 products" },
      { "type": "image_picker", "id": "image", "label": "Image" },
      { "type": "text", "id": "default_asset", "label": "Default asset filename (bundled)" },
      { "type": "url", "id": "link", "label": "Link" }
    ] }
  ],
  "max_blocks": 12,
  "presets": [{
    "name": "Curated collections",
    "blocks": [
      { "type": "tile", "settings": { "title": "Aero" } },
      { "type": "tile", "settings": { "title": "Suspension" } },
      { "type": "tile", "settings": { "title": "Brakes" } },
      { "type": "tile", "settings": { "title": "Drivetrain" } },
      { "type": "tile", "settings": { "title": "Wheels" } },
      { "type": "tile", "settings": { "title": "Interior" } }
    ]
  }]
}
{% endschema %}