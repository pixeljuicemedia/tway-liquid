<section class="catalog-index">
  <div class="container-wide section-pad">
    <div class="section-header">
      <div>
        <p class="eyebrow">{{ section.settings.eyebrow | default: 'Catalog' }}</p>
        <h1 class="section-title">{{ section.settings.heading | default: 'Shop Performance Parts' }}</h1>
      </div>
    </div>

    {%- if collections.size > 0 -%}
      {%- assign visible_collection_count = 0 -%}
      <div class="curated-grid">
        {%- for collection in collections -%}
          {%- unless collection.handle == 'frontpage' -%}
            {%- assign visible_collection_count = visible_collection_count | plus: 1 -%}
            <a href="{{ collection.url }}" class="curated-card">
              {%- assign collection_image = collection.image | default: collection.products.first.featured_image -%}
              {%- if collection_image != blank -%}
                {{ collection_image | image_url: width: 1000 | image_tag: alt: collection.title, loading: 'lazy', widths: '400,600,800,1000' }}
              {%- endif -%}
              <span class="curated-card__grad" aria-hidden="true"></span>
              <span class="curated-card__body">
                <span class="eyebrow">{{ collection.products_count }} products</span>
                <span class="catalog-index__title">{{ collection.title }}</span>
                <span class="curated-card__cta">Shop collection <span aria-hidden="true">&rarr;</span></span>
              </span>
            </a>
          {%- endunless -%}
        {%- endfor -%}
      </div>
      {%- if visible_collection_count == 0 -%}
        <div class="empty-state">
          <p class="empty">Products are available through search while collections are being organized.</p>
          <a href="{{ routes.search_url }}?type=product&amp;q=*" class="btn-primary">Browse all products</a>
        </div>
      {%- endif -%}
    {%- else -%}
      <div class="empty-state">
        <p class="empty">No collections are available yet.</p>
        <a href="{{ routes.search_url }}?type=product&amp;q=*" class="btn-primary">Browse all products</a>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Collection list",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Catalog" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Shop Performance Parts" }
  ]
}
{% endschema %}