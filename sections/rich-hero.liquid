{%- if section.settings.image != blank -%}
  {%- assign rh_bg = section.settings.image | image_url: width: 2000 -%}
{%- elsif section.settings.default_asset != blank -%}
  {%- assign rh_bg = section.settings.default_asset | asset_url -%}
{%- else -%}
  {%- assign rh_bg = '' -%}
{%- endif -%}
<section class="rich-hero"{% if rh_bg != '' %} style="background-image: linear-gradient(180deg, rgba(0,0,0,{{ section.settings.overlay_top | divided_by: 100.0 }}), rgba(0,0,0,{{ section.settings.overlay_bottom | divided_by: 100.0 }})), url('{{ rh_bg }}'); background-size: cover; background-position: center;"{% endif %}>
  <div class="container-wide rich-hero__inner">
    {%- if section.settings.eyebrow != blank -%}<p class="eyebrow">{{ section.settings.eyebrow }}</p>{%- endif -%}
    {%- if section.settings.heading != blank -%}<h1 class="rich-hero__title">{{ section.settings.heading }}</h1>{%- endif -%}
    {%- if section.settings.sub != blank -%}<p class="rich-hero__sub">{{ section.settings.sub }}</p>{%- endif -%}
  </div>
</section>
{% schema %}
{
  "name": "Rich hero",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Background image" },
    { "type": "text", "id": "default_asset", "label": "Default asset filename (bundled)" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow" },
    { "type": "text", "id": "heading", "label": "Heading" },
    { "type": "textarea", "id": "sub", "label": "Subheading" },
    { "type": "range", "id": "overlay_top", "min": 0, "max": 100, "step": 5, "default": 40, "label": "Top overlay %" },
    { "type": "range", "id": "overlay_bottom", "min": 0, "max": 100, "step": 5, "default": 80, "label": "Bottom overlay %" }
  ],
  "presets": [{ "name": "Rich hero" }]
}
{% endschema %}