{%- assign coll = collections[section.settings.collection] -%}
<section class="featured-products hairline-t">
  <div class="container-wide section-pad">
    <div class="section-header">
      <div>
        <p class="eyebrow eyebrow--accent">{{ section.settings.eyebrow | default: 'Featured Products' }}</p>
        <h2 class="section-title">{{ section.settings.heading | default: 'Shop what wins races.' }}</h2>
      </div>
      <a href="{{ section.settings.view_all_link | default: routes.all_products_collection_url }}" class="btn-ghost">{{ section.settings.view_all_label | default: 'View All Products' }} &rarr;</a>
    </div>
    <div class="product-grid product-grid--4">
      {%- if coll.products.size > 0 -%}
        {%- for product in coll.products limit: section.settings.limit -%}
          {% render 'product-card', product: product %}
        {%- endfor -%}
      {%- else -%}
        <p class="empty">No products found. Choose a collection in the theme editor.</p>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured products",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Featured Products" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Shop what wins races." },
    { "type": "collection", "id": "collection", "label": "Collection" },
    { "type": "range", "id": "limit", "label": "Products", "min": 2, "max": 12, "step": 1, "default": 4 },
    { "type": "text", "id": "view_all_label", "label": "View all label", "default": "View All Products" },
    { "type": "url", "id": "view_all_link", "label": "View all link" }
  ],
  "presets": [{ "name": "Featured products" }]
}
{% endschema %}