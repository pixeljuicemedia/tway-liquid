<footer class="site-footer" role="contentinfo">
  <div class="container-wide">
    <div class="site-footer__grid">
      <div class="site-footer__brand">
        {%- if section.settings.logo != blank -%}
          {{ section.settings.logo | image_url: width: 300 | image_tag: alt: shop.name }}
        {%- elsif settings.logo != blank -%}
          {{ settings.logo | image_url: width: 300 | image_tag: alt: shop.name }}
        {%- else -%}
          <img src="{{ 'tway-logo-darkbg.png' | asset_url }}" alt="{{ shop.name | escape }}" style="height:32px;width:auto;display:block;">
        {%- endif -%}
        {%- if section.settings.tagline != blank -%}<p>{{ section.settings.tagline }}</p>{%- endif -%}
        <div class="site-footer__social">
          {%- if settings.social_instagram != blank -%}<a href="{{ settings.social_instagram }}" aria-label="Instagram" target="_blank" rel="noopener">IG</a>{%- endif -%}
          {%- if settings.social_youtube != blank -%}<a href="{{ settings.social_youtube }}" aria-label="YouTube" target="_blank" rel="noopener">YT</a>{%- endif -%}
          {%- if settings.social_facebook != blank -%}<a href="{{ settings.social_facebook }}" aria-label="Facebook" target="_blank" rel="noopener">FB</a>{%- endif -%}
          {%- if settings.social_tiktok != blank -%}<a href="{{ settings.social_tiktok }}" aria-label="TikTok" target="_blank" rel="noopener">TT</a>{%- endif -%}
        </div>
      </div>
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'link_column' -%}
            <div class="site-footer__col">
              <p class="eyebrow neutral">{{ block.settings.heading }}</p>
              <ul>
                {%- assign labels = block.settings.labels | newline_to_br | split: '<br />' -%}
                {%- assign links = block.settings.links | newline_to_br | split: '<br />' -%}
                {%- for label in labels -%}
                  {%- assign href = links[forloop.index0] | default: '#' | strip_html | strip -%}
                  <li><a href="{{ href }}">{{ label | strip_html | strip }}</a></li>
                {%- endfor -%}
              </ul>
            </div>
          {%- when 'visit' -%}
            <div class="site-footer__col">
              <p class="eyebrow neutral">{{ block.settings.heading | default: 'Visit the Shop' }}</p>
              <address>{{ block.settings.address | newline_to_br }}<br><a href="tel:{{ block.settings.phone | replace: ' ', '' | replace: '(', '' | replace: ')', '' | replace: '-', '' }}">{{ block.settings.phone }}</a></address>
              <p class="eyebrow neutral" style="margin-top: 2rem;">Hours</p>
              <p class="hours">{{ block.settings.hours | newline_to_br }}</p>
            </div>
        {%- endcase -%}
      {%- endfor -%}
    </div>
    <div class="site-footer__base">
      <p>&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved. {{ section.settings.tagline_small | default: 'Built by racers.' }}</p>
      <div class="links">
        {%- if section.settings.privacy_link != blank -%}<a href="{{ section.settings.privacy_link }}">Privacy</a>{%- endif -%}
        {%- if section.settings.terms_link != blank -%}<a href="{{ section.settings.terms_link }}">Terms</a>{%- endif -%}
        {%- if section.settings.shipping_link != blank -%}<a href="{{ section.settings.shipping_link }}">Shipping</a>{%- endif -%}
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    { "type": "image_picker", "id": "logo", "label": "Footer logo" },
    { "type": "textarea", "id": "tagline", "label": "Tagline", "default": "Family-owned race shop. Twenty-five years of Corvette engineering, fabrication and trackside experience - engineered for the podium." },
    { "type": "text", "id": "tagline_small", "label": "Small tagline", "default": "Built by racers." },
    { "type": "url", "id": "privacy_link", "label": "Privacy link" },
    { "type": "url", "id": "terms_link", "label": "Terms link" },
    { "type": "url", "id": "shipping_link", "label": "Shipping link" }
  ],
  "blocks": [
    {
      "type": "link_column",
      "name": "Link column",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "Explore" },
        { "type": "textarea", "id": "labels", "label": "Labels (one per line)", "default": "Shop All\nC8 Corvette\nC7 Corvette\nServices\nRace Builds" },
        { "type": "textarea", "id": "links", "label": "Links (one per line, same order)", "default": "/collections\n/collections/c8\n/collections/c7\n/pages/services\n/pages/about" }
      ]
    },
    {
      "type": "visit",
      "name": "Visit / Hours",
      "limit": 1,
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "Visit the Shop" },
        { "type": "textarea", "id": "address", "label": "Address", "default": "210 W Katella Ave, Ste B\nOrange, CA 92867" },
        { "type": "text", "id": "phone", "label": "Phone", "default": "(714) 410-1820" },
        { "type": "textarea", "id": "hours", "label": "Hours", "default": "Mon - Fri  9:00 - 17:00\nSat  By appointment\nSun  Closed" }
      ]
    }
  ],
  "default": {
    "blocks": [
      { "type": "link_column", "settings": { "heading": "Explore", "labels": "Shop All\nC8 Corvette\nC7 Corvette\nServices\nRace Builds", "links": "/collections\n/collections/c8\n/collections/c7\n/pages/services\n/pages/about" } },
      { "type": "link_column", "settings": { "heading": "Company", "labels": "About\nOur Shop\nCareers\nContact", "links": "/pages/about\n/pages/about\n/pages/contact\n/pages/contact" } },
      { "type": "visit", "settings": {} }
    ]
  }
}
{% endschema %}
