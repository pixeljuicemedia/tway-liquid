<div class="container-wide section-pad">
  <p class="eyebrow" style="margin-bottom: 1rem;">{{ section.settings.eyebrow | default: page.title }}</p>
  <h1 style="font-size: clamp(1.75rem, 4vw, 3rem); margin-bottom: 2rem;">{{ page.title }}</h1>
  <div class="prose-product" style="max-width: 46rem; font-size: 16px; line-height: 1.7;">{{ page.content }}</div>
</div>

{% schema %}
{
  "name": "Page content",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow" }
  ]
}
{% endschema %}
