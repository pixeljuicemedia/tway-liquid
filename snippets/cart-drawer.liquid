<aside class="cart-drawer" data-cart-drawer data-open="false" aria-hidden="true">
  <div class="cart-drawer__overlay" data-cart-close></div>
  <div class="cart-drawer__panel" role="dialog" aria-modal="true" aria-label="{{ 'general.cart.title' | t }}">
    <div class="cart-drawer__head">
      <h2>{{ 'general.cart.title' | t }}</h2>
      <button type="button" class="cart-drawer__close" data-cart-close aria-label="{{ 'general.accessibility.close' | t }}">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
    <div class="cart-drawer__body" data-cart-drawer-body>
      <div class="cart-drawer__empty">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 002 1.61h9.72a2 2 0 002-1.61L23 6H6"/></svg>
        <p>{{ 'general.cart.empty' | t }}</p>
      </div>
    </div>
    <div class="cart-drawer__foot" data-cart-drawer-foot style="display: none;">
      <div class="total">
        <span class="label">{{ 'general.cart.subtotal' | t }}</span>
        <span class="value" data-cart-total></span>
      </div>
      <a href="{{ routes.cart_url }}" class="btn-primary" style="width: 100%;">{{ 'general.cart.checkout' | t }}</a>
      <button type="button" class="cart-drawer__continue" data-cart-close>{{ 'general.cart.continue_shopping' | t }}</button>
    </div>
  </div>
</aside>
